# =============================================================================
# Environment Configuration — copy to .env and configure for your environment
# =============================================================================

# Application
DEBUG=false
PORT=8000
LOG_LEVEL=info

# Database — update connection string for your DB
DATABASE_URL=postgresql://app:changeme@db:5432/app
# For SQLite (development only):
# DATABASE_URL=sqlite:///./app.db

# Security — CHANGE THESE IN PRODUCTION
SECRET_KEY=change-me-to-a-long-random-string-in-production
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# PostgreSQL (for docker-compose)
POSTGRES_USER=app
POSTGRES_PASSWORD=changeme
POSTGRES_DB=app
